rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: busca o perfil do usuário autenticado
    function perfil() {
      return get(/databases/$(database)/documents/perfisUsuario/$(request.auth.uid)).data;
    }

    function role() {
      return perfil().role;
    }

    function isAdmin() { return role() == 'admin'; }
    function isOperador() { return role() in ['admin', 'operador']; }
    function isFinanceiro() { return role() in ['admin', 'financeiro']; }
    function isTecnico() { return role() == 'tecnico'; }

    // Instalações
    match /instalacoes/{id} {
      allow read: if request.auth != null && (
        isOperador() ||
        role() == 'financeiro' ||
        (isTecnico() && resource.data.tecnico_id == perfil().tecnico_id)
      );
      allow create: if request.auth != null && isOperador();
      allow update: if request.auth != null && (
        isOperador() ||
        (isTecnico() && resource.data.tecnico_id == perfil().tecnico_id)
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // Técnicos
    match /tecnicos/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Equipamentos
    match /equipamentos/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOperador();
    }

    // Ciclos de faturamento
    match /ciclosFaturamento/{id} {
      allow read, write: if request.auth != null && isFinanceiro();
    }

    // Itens de faturamento
    match /itensFaturamento/{id} {
      allow read, write: if request.auth != null && isFinanceiro();
    }

    // Notificações
    match /notificacoesAlertas/{id} {
      allow read, write: if request.auth != null && isOperador();
    }

    // Perfis de usuário
    match /perfisUsuario/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if request.auth != null && isAdmin();
    }
  }
}
